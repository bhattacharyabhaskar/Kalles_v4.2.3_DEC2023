    "6869956b-0118-467c-98f0-cbb9ff121db9": {
      "type": "image_text",
      "blocks": {
        "template--17119026708713__6869956b-0118-467c-98f0-cbb9ff121db9-bl_text-1": {
          "type": "bl_text",
